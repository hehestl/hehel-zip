# Hehel Zip — environment variables (optional)
# Copy to .env.local for local overrides. Never commit real secrets.

# Vite dev server (default in tauri.conf.json)
# VITE_DEV_SERVER_URL=http://localhost:1420

# Hestia / Heron defaults are configured in the app UI (Sync settings).
# OAuth tokens are stored in the OS keychain, NOT in .env.
# HERON_AUTH_URL=https://auth.hehestl.com
# HCOM_API_URL=https://hehestl.com

# Rust logging (dev / diagnostics)
# RUST_LOG=info