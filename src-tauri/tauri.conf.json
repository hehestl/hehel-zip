{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hehel Zip",
  "version": "0.3.0",
  "identifier": "com.hehestl.hehel-zip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hehel Zip",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.hehestl.com http://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: hehe: hehe://localhost http://hehe.localhost https://hehe.localhost asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "fileAssociations": [
      {
        "ext": ["hehe"],
        "name": "Hehel Archive",
        "description": "Arhive files created by Hehel Zip",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/7z/*", "assets/drag-out-stack.png"]
  },
  "plugins": {}
}
